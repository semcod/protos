{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "IdentifyUserCommand": {
      "type": "object",
      "properties": {
        "command_id": {
          "type": "string"
        },
        "identifier": {
          "type": "string"
        },
        "type": {
          "type": "object"
        }
      },
      "required": [
        "command_id",
        "identifier",
        "type"
      ],
      "additionalProperties": false
    },
    "UserIdentificationReadModel": {
      "type": "object",
      "properties": {
        "user_id": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "identified_at": {
          "type": "object"
        }
      },
      "required": [
        "user_id",
        "display_name",
        "roles",
        "identified_at"
      ],
      "additionalProperties": false
    },
    "UserIdentifiedEvent": {
      "type": "object",
      "properties": {
        "event_id": {
          "type": "string"
        },
        "user_id": {
          "type": "string"
        },
        "type": {
          "type": "object"
        },
        "occurred_at": {
          "type": "object"
        }
      },
      "required": [
        "event_id",
        "user_id",
        "type",
        "occurred_at"
      ],
      "additionalProperties": false
    }
  }
}
