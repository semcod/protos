{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "LegacyUser": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "first_name": {
          "type": "string"
        },
        "last_name": {
          "type": "string"
        },
        "age": {
          "type": "integer"
        },
        "is_active": {
          "type": "boolean"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "email",
        "first_name",
        "last_name",
        "age",
        "is_active",
        "tags"
      ],
      "additionalProperties": false
    }
  }
}
