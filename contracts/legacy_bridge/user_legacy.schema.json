{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LegacyUser",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "email": { "type": "string" },
    "first_name": { "type": "string" },
    "last_name": { "type": "string" },
    "age": { "type": "integer" },
    "is_active": { "type": "boolean" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["id", "email"]
}
